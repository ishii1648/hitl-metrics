{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 100,
      "title": "状態評価 — 開発活動の推移",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "活動量サマリー",
      "description": "期間内の活動量・スループット指標。PR の複雑度に依存しない集計のみ表示する",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(DISTINCT s.session_id) AS 'sessions' FROM sessions s LEFT JOIN transcript_stats ts ON s.session_id = ts.session_id WHERE s.is_subagent = 0 AND COALESCE(ts.is_ghost, 0) = 0 AND s.repo NOT IN ('ishii1648/dotfiles') AND s.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}'",
          "refId": "A"
        },
        {
          "rawQueryText": "SELECT COUNT(*) AS 'merged PRs' FROM pr_merged_at_approx WHERE merged_at_approx BETWEEN '${__from:date:iso}' AND '${__to:date:iso}'",
          "refId": "B"
        },
        {
          "rawQueryText": "SELECT COALESCE(SUM(ts.input_tokens + ts.output_tokens + ts.cache_write_tokens + ts.cache_read_tokens), 0) AS 'total tokens' FROM sessions s LEFT JOIN transcript_stats ts ON s.session_id = ts.session_id WHERE s.is_subagent = 0 AND COALESCE(ts.is_ghost, 0) = 0 AND s.repo NOT IN ('ishii1648/dotfiles') AND s.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}'",
          "refId": "C"
        },
        {
          "rawQueryText": "SELECT COALESCE(MAX(peak_concurrent_sessions), 0) AS 'peak concurrent' FROM session_concurrency_daily WHERE day BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}')",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total tokens" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 9,
      "title": "週別 token 消費",
      "description": "週単位の総 tokens（コスト推移）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, total_tokens FROM weekly_session_metrics WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#2563eb", "mode": "fixed" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 20,
      "title": "週別 セッション数 / merged PR 数",
      "description": "活動量とスループットの推移",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, session_count FROM weekly_session_metrics WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        },
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, merged_pr_count FROM weekly_pr_metrics WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "B",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "merged_pr_count" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 16,
      "title": "週別 concurrent sessions",
      "description": "トップレベル Claude Code セッションの週別平均・最大同時実行数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, avg_concurrent_sessions, peak_concurrent_sessions FROM session_concurrency_weekly WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 2,
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "peak_concurrent_sessions" },
            "properties": [{ "id": "decimals", "value": 0 }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 12,
      "title": "週別 PR / 1M tokens",
      "description": "期間集計の効率指標。PR 単位ではなく週内で平均化されているため複雑度差は均される",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', wpr.week_start) AS time, ROUND(wpr.merged_pr_count * 1000000.0 / NULLIF(wsm.total_tokens, 0), 2) AS pr_per_million_tokens FROM weekly_pr_metrics wpr JOIN weekly_session_metrics wsm ON wpr.week_start = wsm.week_start WHERE wpr.week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#16a34a", "mode": "fixed" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 21,
      "title": "週別 tokens / session・ask_user_question / session",
      "description": "期間集計のセッション効率と指示不足傾向の推移",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, tokens_per_session, ask_user_question_per_session FROM weekly_session_metrics WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ask_user_question_per_session" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "decimals", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 22,
      "title": "週別 changes_requested 発生率 / merge までの avg session 数",
      "description": "リワーク傾向と PR 完了までに要したセッション数の推移",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, changes_requested_rate, avg_sessions_per_pr FROM weekly_pr_metrics WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "changes_requested_rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_sessions_per_pr" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "decimals", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 102,
      "title": "改善のきっかけ — PR 単位の外れ値検出",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "PR 別 token スコアカード（merged のみ）",
      "description": "merged PR ごとの token 消費・効率・品質指標一覧。複雑度の異なる PR を比較するのではなく、外れ値を発見しドリルダウンする用途",
      "type": "table",
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT replace(replace(pr_url, 'https://github.com/', ''), '/pull/', '#') AS pr, total_tokens, tokens_per_tool_use, pr_per_million_tokens, session_count, mid_session_msgs, ask_user_question, changes_requested, pr_url FROM pr_metrics WHERE total_tokens > 0 ORDER BY total_tokens DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr" },
            "properties": [
              { "id": "links", "value": [{ "title": "Open PR", "url": "${__data.fields.pr_url}" }] },
              { "id": "custom.width", "value": 240 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pr_url" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_tokens" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 120 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/.*tokens.*/" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "lg",
        "sortBy": [{ "displayName": "total_tokens", "desc": true }]
      }
    },
    {
      "id": 14,
      "title": "PR 別 session_count 分布",
      "description": "多セッション PR の外れ値検出。脱線・やり直しの兆候。上位 10 件のみ",
      "type": "barchart",
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT replace(replace(pr_url, 'https://github.com/', ''), '/pull/', '#') AS pr, session_count FROM pr_metrics ORDER BY session_count DESC, pr_url LIMIT 10",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#64748b", "mode": "fixed" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 15,
      "title": "PR 別 tokens / tool_use",
      "description": "1 tool_use あたりの token 消費が大きい PR。ファイル肥大・無駄な再読みの兆候。上位 10 件のみ",
      "type": "barchart",
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 34 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT replace(replace(pr_url, 'https://github.com/', ''), '/pull/', '#') AS pr, tokens_per_tool_use FROM pr_metrics WHERE tokens_per_tool_use IS NOT NULL ORDER BY tokens_per_tool_use DESC, pr_url LIMIT 10",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#dc2626", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 23,
      "title": "リワークホットスポット",
      "description": "changes_requested・ask_user_question・mid_session_msgs を組み合わせて、指示不足やリワーク多発 PR を検出する",
      "type": "table",
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 34 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT replace(replace(pr_url, 'https://github.com/', ''), '/pull/', '#') AS pr, changes_requested, ask_user_question, mid_session_msgs, session_count, pr_url FROM pr_metrics WHERE changes_requested > 0 OR ask_user_question > 0 OR mid_session_msgs > 0 ORDER BY changes_requested DESC, ask_user_question DESC, mid_session_msgs DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr" },
            "properties": [
              { "id": "links", "value": [{ "title": "Open PR", "url": "${__data.fields.pr_url}" }] },
              { "id": "custom.width", "value": 240 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pr_url" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "changes_requested" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "lg",
        "sortBy": [{ "displayName": "changes_requested", "desc": true }]
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["hitl-metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Tokyo",
  "title": "Claude token 効率ダッシュボード",
  "uid": "hitl-metrics",
  "version": 1
}
