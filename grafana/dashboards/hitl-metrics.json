{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 100,
      "title": "ヘッドライン",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "サマリー",
      "description": "merged PR の主要指標サマリー",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) AS 'merged PR 数' FROM pr_metrics",
          "refId": "A"
        },
        {
          "rawQueryText": "SELECT ROUND(AVG(perm_rate), 1) AS 'avg perm rate (%)' FROM pr_metrics WHERE perm_rate IS NOT NULL",
          "refId": "B"
        },
        {
          "rawQueryText": "SELECT COALESCE(SUM(mid_session_msgs), 0) AS 'mid-session msgs' FROM pr_metrics",
          "refId": "C"
        },
        {
          "rawQueryText": "SELECT COALESCE(SUM(review_comments), 0) AS 'review comments' FROM pr_metrics",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg perm rate (%)" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "red", "value": 15 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 101,
      "title": "トレンド",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "perm rate 週別トレンド",
      "description": "週単位の permission 発生率推移",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', date(pe.timestamp, 'weekday 0', '-6 days')) AS time, COUNT(pe.id) AS perm_count, COALESCE(SUM(ts.tool_use_total), 0) AS tool_use_total, CASE WHEN COALESCE(SUM(ts.tool_use_total), 0) > 0 THEN ROUND(COUNT(pe.id) * 100.0 / SUM(ts.tool_use_total), 1) ELSE NULL END AS perm_rate FROM permission_events pe LEFT JOIN sessions s ON pe.session_id = s.session_id LEFT JOIN transcript_stats ts ON pe.session_id = ts.session_id WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND s.repo NOT IN ('ishii1648/dotfiles') GROUP BY date(pe.timestamp, 'weekday 0', '-6 days') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#ef4444", "mode": "fixed" },
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "perm_count" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          },
          {
            "matcher": { "id": "byName", "options": "tool_use_total" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 12,
      "title": "タスク種別 perm rate",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT CASE WHEN task_type = '' THEN 'other' ELSE task_type END AS task_type, ROUND(SUM(perm_count) * 100.0 / NULLIF(SUM(tool_use_total), 0), 1) AS perm_rate, COUNT(*) AS pr_count FROM pr_metrics GROUP BY task_type ORDER BY perm_rate DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#a855f7", "mode": "fixed" },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr_count" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 102,
      "title": "PR 詳細",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "PR 別スコアカード（merged のみ）",
      "description": "merged PR ごとの介入指標・品質指標一覧",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT pm.pr_url, pm.task_type, pm.perm_rate, pm.perm_count, pm.session_count, pm.mid_session_msgs, pm.ask_user_question, pm.review_comments, pm.tool_use_total FROM pr_metrics pm ORDER BY pm.perm_rate DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr_url" },
            "properties": [
              { "id": "links", "value": [{ "title": "Open PR", "url": "${__data.fields.pr_url}" }] },
              { "id": "custom.width", "value": 320 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "task_type" },
            "properties": [
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "perm_rate" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.width", "value": 120 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "red", "value": 15 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "perm_rate", "desc": true }]
      }
    },
    {
      "id": 103,
      "title": "アクション: allowlist 改善",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "title": "ツール別 permission 内訳",
      "description": "ツールごとの permission 発生回数と割合",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT pe.tool, COUNT(*) AS count, ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM permission_events WHERE timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}'), 1) AS percentage FROM permission_events pe WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND pe.tool != 'unknown' GROUP BY pe.tool ORDER BY count DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "percentage" },
            "properties": [{ "id": "unit", "value": "percent" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "count", "desc": true }]
      }
    },
    {
      "id": 11,
      "title": "ツール別 permission 分布",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT pe.tool, COUNT(*) AS count FROM permission_events pe WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND pe.tool != 'unknown' GROUP BY pe.tool ORDER BY count DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#06b6d4", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["hitl-metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Tokyo",
  "title": "Claude 自律度ダッシュボード",
  "uid": "hitl-metrics",
  "version": 1
}
