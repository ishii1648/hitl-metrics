{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 100,
      "title": "ヘッドライン",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "サマリー",
      "description": "merged PR のトークン効率サマリー",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) AS 'merged PR 数' FROM pr_metrics WHERE total_tokens > 0",
          "refId": "A"
        },
        {
          "rawQueryText": "SELECT COALESCE(SUM(total_tokens), 0) AS 'total tokens' FROM pr_metrics WHERE total_tokens > 0",
          "refId": "B"
        },
        {
          "rawQueryText": "SELECT COALESCE(ROUND(AVG(total_tokens), 0), 0) AS 'avg tokens / PR' FROM pr_metrics WHERE total_tokens > 0",
          "refId": "C"
        },
        {
          "rawQueryText": "SELECT COALESCE(ROUND(COUNT(*) * 1000000.0 / NULLIF(SUM(total_tokens), 0), 2), 0) AS 'PR / 1M tokens' FROM pr_metrics WHERE total_tokens > 0",
          "refId": "D"
        },
        {
          "rawQueryText": "SELECT COALESCE(SUM(changes_requested), 0) AS 'changes requested' FROM pr_metrics",
          "refId": "E"
        },
        {
          "rawQueryText": "SELECT COALESCE(MAX(peak_concurrent_sessions), 0) AS 'peak concurrent sessions' FROM session_concurrency_daily",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total tokens" },
            "properties": [{ "id": "unit", "value": "short" }]
          },
          {
            "matcher": { "id": "byName", "options": "avg tokens / PR" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 101,
      "title": "トレンド",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "週別 token 消費",
      "description": "週単位の total_tokens と merged PR 数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', date(s.timestamp, 'weekday 0', '-6 days')) AS time, COALESCE(SUM(pm.total_tokens), 0) AS total_tokens, COUNT(DISTINCT pm.pr_url) AS merged_prs FROM pr_metrics pm JOIN sessions s ON pm.pr_url = s.pr_url WHERE s.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND pm.total_tokens > 0 AND s.is_subagent = 0 GROUP BY date(s.timestamp, 'weekday 0', '-6 days') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#2563eb", "mode": "fixed" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "merged_prs" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 12,
      "title": "週別 PR / 1M tokens",
      "description": "同じ token 消費で完了できた PR 数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', date(s.timestamp, 'weekday 0', '-6 days')) AS time, ROUND(COUNT(DISTINCT pm.pr_url) * 1000000.0 / NULLIF(SUM(pm.total_tokens), 0), 2) AS pr_per_million_tokens FROM pr_metrics pm JOIN sessions s ON pm.pr_url = s.pr_url WHERE s.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND pm.total_tokens > 0 AND s.is_subagent = 0 GROUP BY date(s.timestamp, 'weekday 0', '-6 days') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#16a34a", "mode": "fixed" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 16,
      "title": "週別 concurrent sessions",
      "description": "トップレベル Claude Code セッションの週別平均・最大同時実行数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', week_start) AS time, avg_concurrent_sessions, peak_concurrent_sessions FROM session_concurrency_weekly WHERE week_start BETWEEN date('${__from:date:iso}') AND date('${__to:date:iso}') ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#7c3aed", "mode": "palette-classic" },
          "unit": "short",
          "decimals": 2,
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "peak_concurrent_sessions" },
            "properties": [{ "id": "decimals", "value": 0 }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 13,
      "title": "タスク種別 avg tokens / PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT CASE WHEN task_type = '' THEN 'other' ELSE task_type END AS task_type, ROUND(AVG(total_tokens), 0) AS avg_tokens_per_pr, COUNT(*) AS pr_count FROM pr_metrics WHERE total_tokens > 0 GROUP BY task_type ORDER BY avg_tokens_per_pr DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#f59e0b", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr_count" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 102,
      "title": "PR 詳細",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "PR 別 token スコアカード（merged のみ）",
      "description": "merged PR ごとの token 消費・効率・品質指標一覧",
      "type": "table",
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 15 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT pr_url, task_type, total_tokens, tokens_per_tool_use, pr_per_million_tokens, session_count, mid_session_msgs, ask_user_question, changes_requested FROM pr_metrics WHERE total_tokens > 0 ORDER BY total_tokens DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr_url" },
            "properties": [
              { "id": "links", "value": [{ "title": "Open PR", "url": "${__data.fields.pr_url}" }] },
              { "id": "custom.width", "value": 300 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_tokens" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 120 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/.*tokens.*/" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "total_tokens", "desc": true }]
      }
    },
    {
      "id": 14,
      "title": "PR 別 session_count 分布",
      "description": "多セッション PR の外れ値検出",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT replace(replace(pr_url, 'https://github.com/', ''), '/pull/', '#') AS pr, session_count FROM pr_metrics ORDER BY session_count DESC, pr_url",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#64748b", "mode": "fixed" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 15,
      "title": "PR 別 tokens / tool_use",
      "description": "1 tool_use あたりの token 消費が大きい PR",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 21 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "hitl-metrics" },
      "targets": [
        {
          "rawQueryText": "SELECT replace(replace(pr_url, 'https://github.com/', ''), '/pull/', '#') AS pr, tokens_per_tool_use FROM pr_metrics WHERE tokens_per_tool_use IS NOT NULL ORDER BY tokens_per_tool_use DESC, pr_url LIMIT 20",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#dc2626", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.8
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["hitl-metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Tokyo",
  "title": "Claude token 効率ダッシュボード",
  "uid": "hitl-metrics",
  "version": 1
}
