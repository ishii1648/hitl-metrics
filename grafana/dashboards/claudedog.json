        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 6,
      "title": "mid-session msgs by PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pr_url, mid_session_msgs FROM pr_metrics ORDER BY mid_session_msgs DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#eab308", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 7,
      "title": "AskUserQuestion by PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pr_url, ask_user_question FROM pr_metrics ORDER BY ask_user_question DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#22c55e", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 12,
      "title": "タスク種別 perm rate",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT CASE WHEN task_type = '' THEN 'other' ELSE task_type END AS task_type, ROUND(SUM(perm_count) * 100.0 / NULLIF(SUM(tool_use_total), 0), 1) AS perm_rate, COUNT(*) AS pr_count FROM pr_metrics GROUP BY task_type ORDER BY perm_rate DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#a855f7", "mode": "fixed" },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr_count" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 13,
      "title": "タスク種別テーブル",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT CASE WHEN task_type = '' THEN 'other' ELSE task_type END AS task_type, COUNT(*) AS pr_count, SUM(session_count) AS session_count, SUM(perm_count) AS perm_count, ROUND(SUM(perm_count) * 100.0 / NULLIF(SUM(tool_use_total), 0), 1) AS perm_rate, ROUND(AVG(review_comments), 1) AS avg_review_comments FROM pr_metrics GROUP BY task_type ORDER BY pr_count DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "perm_rate" },
            "properties": [{ "id": "unit", "value": "percent" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "pr_count", "desc": true }]
      }
    },
    {
      "id": 14,
      "title": "review comments by PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 46 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pr_url, review_comments FROM pr_metrics WHERE review_comments > 0 ORDER BY review_comments DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#f43f5e", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 8,
      "title": "perm rate 日別トレンド",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', date(pe.timestamp)) AS time, COUNT(pe.id) AS perm_count, COALESCE(SUM(ts.tool_use_total), 0) AS tool_use_total, CASE WHEN COALESCE(SUM(ts.tool_use_total), 0) > 0 THEN ROUND(COUNT(pe.id) * 100.0 / SUM(ts.tool_use_total), 1) ELSE NULL END AS perm_rate FROM permission_events pe LEFT JOIN sessions s ON pe.session_id = s.session_id LEFT JOIN transcript_stats ts ON pe.session_id = ts.session_id WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND s.repo NOT IN ('ishii1648/dotfiles') GROUP BY date(pe.timestamp) ORDER BY time",
          "timeColumns": ["time"],
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#ef4444", "mode": "fixed" },
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "perm_count" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          },
          {
            "matcher": { "id": "byName", "options": "tool_use_total" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "title": "perm rate 週別トレンド",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT strftime('%s', date(pe.timestamp, 'weekday 0', '-6 days')) AS time, COUNT(pe.id) AS perm_count, COALESCE(SUM(ts.tool_use_total), 0) AS tool_use_total, CASE WHEN COALESCE(SUM(ts.tool_use_total), 0) > 0 THEN ROUND(COUNT(pe.id) * 100.0 / SUM(ts.tool_use_total), 1) ELSE NULL END AS perm_rate FROM permission_events pe LEFT JOIN sessions s ON pe.session_id = s.session_id LEFT JOIN transcript_stats ts ON pe.session_id = ts.session_id WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND s.repo NOT IN ('ishii1648/dotfiles') GROUP BY date(pe.timestamp, 'weekday 0', '-6 days') ORDER BY time",
          "timeColumns": ["time"],
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#ef4444", "mode": "fixed" },
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "perm_count" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          },
          {
            "matcher": { "id": "byName", "options": "tool_use_total" },
            "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": true } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 10,
      "title": "ツール別内訳テーブル",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pe.tool, COUNT(*) AS count, ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM permission_events WHERE timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}'), 1) AS percentage FROM permission_events pe WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND pe.tool != 'unknown' GROUP BY pe.tool ORDER BY count DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "percentage" },
            "properties": [{ "id": "unit", "value": "percent" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "count", "desc": true }]
      }
    },
    {
      "id": 11,
      "title": "ツール別内訳バー",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pe.tool, COUNT(*) AS count FROM permission_events pe WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' AND pe.tool != 'unknown' GROUP BY pe.tool ORDER BY count DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#06b6d4", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    }
  ],
