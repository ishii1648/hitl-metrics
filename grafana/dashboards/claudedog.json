{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "サマリ",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT COUNT(*) AS pr_count, COALESCE(SUM(perm_count), 0) AS total_perm FROM pr_metrics WHERE pr_url IN (SELECT DISTINCT s.pr_url FROM sessions s LEFT JOIN permission_events pe ON s.session_id = pe.session_id WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}')",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "title": "PR 別テーブル（merged のみ）",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pm.pr_url, pm.task_type, pm.session_count, pm.tool_use_total, pm.mid_session_msgs, pm.ask_user_question, pm.perm_count, pm.perm_rate, pm.review_comments FROM pr_metrics pm WHERE pm.pr_url IN (SELECT DISTINCT s.pr_url FROM sessions s LEFT JOIN permission_events pe ON s.session_id = pe.session_id WHERE pe.timestamp BETWEEN '${__from:date:iso}' AND '${__to:date:iso}' OR pe.timestamp IS NULL) ORDER BY pm.perm_rate ASC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pr_url" },
            "properties": [
              { "id": "links", "value": [{ "title": "Open PR", "url": "${__data.fields.pr_url}" }] },
              { "id": "custom.width", "value": 300 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "perm_rate" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "task_type" },
            "properties": [
              { "id": "custom.width", "value": 80 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "perm_rate", "desc": false }]
      }
    },
    {
      "id": 3,
      "title": "perm rate by PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pr_url, perm_rate FROM pr_metrics WHERE perm_rate IS NOT NULL ORDER BY perm_rate ASC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#ef4444", "mode": "fixed" },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
      }
    },
    {
      "id": 4,
      "title": "perm count by PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
