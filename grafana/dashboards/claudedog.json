      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#f97316", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8
