    {
      "id": 5,
      "title": "session count by PR",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "claudedog" },
      "targets": [
        {
          "rawQueryText": "SELECT pr_url, session_count FROM pr_metrics ORDER BY session_count DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
