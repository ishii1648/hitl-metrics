<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.hitl-metrics-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>hitl-metrics backfill; hitl-metrics sync-db</string>
  </array>

  <!-- PATH に hitl-metrics が含まれるよう設定 -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__HITL_METRICS_BIN_DIR__:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>__HOME__</string>
  </dict>

  <!-- ログイン時に即実行 -->
  <key>RunAtLoad</key>
  <true/>

  <!-- 毎時 0 分に実行 -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__HOME__/.claude/logs/hitl-metrics-sync.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.claude/logs/hitl-metrics-sync.log</string>
</dict>
</plist>
